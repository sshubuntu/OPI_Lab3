package com.sshubuntu.weblab3.bean;

import com.sshubuntu.weblab3.i18n.MessageProvider;
import jakarta.enterprise.context.ApplicationScoped;
import jakarta.inject.Named;

@Named("studentInfo")
@ApplicationScoped
public class StudentInfoBean {

    private final String fullName = MessageProvider.get("student.fullName");
    private final String group = MessageProvider.get("student.group");
    private final String variant = MessageProvider.get("student.variant");

    public String getFullName() {
        return fullName;
    }

    public String getGroup() {
        return group;
    }

    public String getVariant() {
        return variant;
    }
}





