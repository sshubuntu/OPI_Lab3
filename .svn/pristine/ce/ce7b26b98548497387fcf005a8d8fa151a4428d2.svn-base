<?xml version="1.0" encoding="UTF-8"?>
<project name="WEB_Lab3" default="build" basedir=".">
    <property file="ant.properties"/>

    <path id="compile.classpath">
        <fileset dir="${lib.dir}" includes="**/*.jar" erroronmissingdir="false"/>
    </path>

    <path id="test.classpath">
        <pathelement location="${classes.dir}"/>
        <pathelement location="${test.classes.dir}"/>
        <path refid="compile.classpath"/>
        <pathelement location="${junit.jar}"/>
        <pathelement location="${hamcrest.jar}"/>
    </path>

    <target name="init">
        <mkdir dir="${build.dir}"/>
        <mkdir dir="${classes.dir}"/>
        <mkdir dir="${test.classes.dir}"/>
        <mkdir dir="${dist.dir}"/>
        <mkdir dir="${reports.dir}"/>
        <mkdir dir="${xml.report.dir}"/>
        <mkdir dir="${native2ascii.dir}"/>
        <mkdir dir="${javadoc.dir}"/>
        <mkdir dir="${tmp.dir}"/>
    </target>

    <target name="compile" depends="init" description="Compile project sources">
        <javac srcdir="${src.dir}"
               destdir="${classes.dir}"
               source="${javac.source}"
               target="${javac.target}"
               encoding="${javac.encoding}"
               includeantruntime="false">
            <classpath refid="compile.classpath"/>
        </javac>
        <copy todir="${classes.dir}">
            <fileset dir="${resources.dir}" erroronmissingdir="false"/>
        </copy>
    </target>

    <target name="detect-tests" depends="init">
        <condition property="test.src.present">
            <available file="${test.src.dir}" type="dir"/>
        </condition>
        <condition property="junit.present">
            <and>
                <available file="${junit.jar}"/>
                <available file="${hamcrest.jar}"/>
            </and>
        </condition>
    </target>

    <target name="detect-svn">
        <condition property="svn.wc.present">
            <available file=".svn" type="dir"/>
        </condition>
    </target>

    <target name="build" depends="compile" description="Compile and package executable JAR">
        <jar destfile="${dist.dir}/${jar.name}" manifest="${manifest.file}" basedir="${classes.dir}"/>
    </target>

    <target name="clean" description="Remove build artifacts">
        <delete dir="${build.dir}"/>
        <delete dir="${dist.dir}"/>
    </target>

    <target name="test-runner" depends="build,detect-tests" if="test.src.present">
        <fail unless="junit.present" message="JUnit libraries are not configured. Set junit.jar and hamcrest.jar in ant.properties."/>
        <javac srcdir="${test.src.dir}"
               destdir="${test.classes.dir}"
               source="${javac.source}"
               target="${javac.target}"
               encoding="${javac.encoding}"
               includeantruntime="false"
               failonerror="false">
            <classpath refid="test.classpath"/>
        </javac>

        <junit printsummary="yes" haltonfailure="true" fork="true">
            <classpath refid="test.classpath"/>
            <formatter type="xml"/>
            <batchtest todir="${xml.report.dir}">
                <fileset dir="${test.src.dir}" includes="${test.includes}" erroronmissingdir="false"/>
            </batchtest>
        </junit>
    </target>

    <target name="test-skip" depends="build,detect-tests" unless="test.src.present">
        <echo message="No tests found: ${test.src.dir} does not exist. Skipping test execution."/>
    </target>

    <target name="test" depends="test-runner,test-skip" description="Build and run JUnit tests"/>

    <target name="native2ascii" depends="init" description="Convert localization files to ASCII">
        <copy todir="${native2ascii.dir}">
            <fileset dir="${resources.dir}" includes="${i18n.includes}" erroronmissingdir="false"/>
        </copy>
        <mkdir dir="${native2ascii.dir}/ascii"/>
        <native2ascii src="${native2ascii.dir}"
                      dest="${native2ascii.dir}/ascii"
                      includes="${i18n.includes}"
                      encoding="UTF-8"
                      ext=".ascii.properties"/>
    </target>

    <target name="xml" description="Validate all XML files in project">
        <xmlvalidate lenient="true" warn="true">
            <fileset dir="."
                     includes="${xml.includes}"
                     excludes="${build.dir}/**,tools/**,.gradle/**,wildfly-37.0.1.Final/**"/>
        </xmlvalidate>
    </target>

    <target name="music" depends="build" description="Play music after successful build" if="music.enabled">
        <exec executable="powershell" failonerror="false">
            <arg value="-NoProfile"/>
            <arg value="-Command"/>
            <arg value="[console]::beep(880,250); [console]::beep(988,250); [console]::beep(1047,300)"/>
        </exec>
    </target>

    <target name="prepare-doc-fileset" depends="build">
        <mkdir dir="${checksums.dir}"/>
        <copy todir="${checksums.dir}">
            <fileset dir="${src.dir}" includes="**/*"/>
            <fileset dir="${resources.dir}" includes="**/*" erroronmissingdir="false"/>
            <fileset dir="${web.dir}" includes="**/*" erroronmissingdir="false"/>
            <fileset dir="." includes="build.xml,ant.properties,META-INF/MANIFEST.MF"/>
        </copy>
    </target>

    <target name="generate-checksums" depends="prepare-doc-fileset">
        <checksum algorithm="MD5" fileext=".md5">
            <fileset dir="${checksums.dir}" includes="**/*" excludes="**/*.md5,**/*.sha1"/>
        </checksum>
        <checksum algorithm="SHA-1" fileext=".sha1">
            <fileset dir="${checksums.dir}" includes="**/*" excludes="**/*.md5,**/*.sha1"/>
        </checksum>
        <checksum algorithm="MD5" totalproperty="project.md5">
            <fileset dir="${checksums.dir}" includes="**/*" excludes="**/*.md5,**/*.sha1"/>
        </checksum>
        <checksum algorithm="SHA-1" totalproperty="project.sha1">
            <fileset dir="${checksums.dir}" includes="**/*" excludes="**/*.md5,**/*.sha1"/>
        </checksum>
    </target>

    <target name="doc" depends="generate-checksums" description="Add checksums and Javadocs to JAR">
        <javadoc sourcepath="${src.dir}" destdir="${javadoc.dir}" encoding="${javac.encoding}" failonerror="false">
            <classpath refid="compile.classpath"/>
        </javadoc>

        <manifest file="${tmp.dir}/manifest-doc.mf">
            <attribute name="Manifest-Version" value="1.0"/>
            <attribute name="Implementation-Version" value="${project.version}"/>
            <attribute name="Main-Class" value="${main.class}"/>
            <attribute name="Project-MD5" value="${project.md5}"/>
            <attribute name="Project-SHA1" value="${project.sha1}"/>
        </manifest>

        <jar destfile="${dist.dir}/${jar.name}" manifest="${tmp.dir}/manifest-doc.mf" update="false">
            <fileset dir="${classes.dir}"/>
            <zipfileset dir="${checksums.dir}" prefix="docs/checksums" includes="**/*.md5,**/*.sha1"/>
            <zipfileset dir="${javadoc.dir}" prefix="docs/javadoc"/>
        </jar>
    </target>

    <target name="scp" depends="build" description="Upload built JAR over SCP">
        <exec executable="wsl" failonerror="false">
            <arg value="bash"/>
            <arg value="-lc"/>
            <arg value="cd '${wsl.project.dir}' &amp;&amp; scp -o BatchMode=yes -o StrictHostKeyChecking=no -o ConnectTimeout=5 -P ${scp.port} './${dist.dir}/${jar.name}' '${scp.user}@${scp.host}:${scp.remote.path}'"/>
        </exec>
    </target>

    <target name="diff-run" depends="detect-svn" if="svn.wc.present">
        <exec executable="wsl" failonerror="false">
            <arg value="bash"/>
            <arg value="-lc"/>
            <arg value="cd '${wsl.project.dir}' &amp;&amp; status=&quot;$(svn status)&quot;; if [ -z &quot;$status&quot; ]; then exit 0; fi; echo &quot;$status&quot; | grep -E '${diff.excluded.classes.regex}' &gt;/dev/null &amp;&amp; { echo 'Commit blocked by excluded classes'; exit 0; }; svn commit -m '${svn.commit.message}'"/>
        </exec>
    </target>

    <target name="diff-skip" depends="detect-svn" unless="svn.wc.present">
        <echo message="SVN working copy not found (.svn is missing). Skipping diff target."/>
    </target>

    <target name="diff" depends="diff-run,diff-skip" description="Commit SVN changes if allowed"/>

    <target name="alt" depends="build" description="Build alternative obfuscated variant">
        <copy todir="${tmp.dir}/alt-src">
            <fileset dir="${src.dir}"/>
        </copy>
        <mkdir dir="${tmp.dir}/alt-classes"/>
        <replace dir="${tmp.dir}/alt-src" includes="**/*.java" token="${replace.from}" value="${replace.to}"/>
        <replaceregexp byline="true" match="${replaceregexp.match}" replace="${replaceregexp.replace}">
            <fileset dir="${tmp.dir}/alt-src" includes="**/*.java"/>
        </replaceregexp>
        <javac srcdir="${tmp.dir}/alt-src"
               destdir="${tmp.dir}/alt-classes"
               source="${javac.source}"
               target="${javac.target}"
               encoding="${javac.encoding}"
               includeantruntime="false">
            <classpath refid="compile.classpath"/>
        </javac>
        <jar destfile="${dist.dir}/${alt.jar.name}" manifest="${manifest.file}" basedir="${tmp.dir}/alt-classes"/>
    </target>

    <target name="team-run" depends="detect-svn" if="svn.wc.present">
        <exec executable="wsl" failonerror="false">
            <arg value="bash"/>
            <arg value="-lc"/>
            <arg value="cd '${wsl.project.dir}' &amp;&amp; root='${wsl.project.dir}/${tmp.dir}/team'; mkdir -p &quot;$root&quot;; rev=&quot;$(svn info --show-item revision)&quot;; for i in 1 2 3; do old_rev=$((rev-i)); dst=&quot;$root/r$old_rev&quot;; svn export -r &quot;$old_rev&quot; . &quot;$dst&quot; --force &gt;/dev/null; ${wsl.ant.executable} -f &quot;$dst/build.xml&quot; build; cp &quot;$dst&quot;/dist/*.jar &quot;$root&quot;/; done; cd &quot;$root&quot; &amp;&amp; zip -j '${wsl.project.dir}/${dist.dir}/team-revisions.zip' ./*.jar -q"/>
        </exec>
    </target>

    <target name="team-skip" depends="detect-svn" unless="svn.wc.present">
        <echo message="SVN working copy not found (.svn is missing). Skipping team target."/>
    </target>

    <target name="team" depends="team-run,team-skip" description="Build previous SVN revisions and zip them"/>

    <target name="env" depends="build" description="Build and run in alternative environments">
        <exec executable="powershell" failonerror="false">
            <arg value="-NoProfile"/>
            <arg value="-Command"/>
            <arg value="$versions='${env.java.versions}'.Split(','); foreach($v in $versions){$javaExe=&amp; where.exe java | Select-Object -First 1; if($javaExe){Write-Host ('Running with Java '+$v); &amp; $javaExe ${env.jvm.args} -jar '${dist.dir}/${jar.name}' ${env.program.args}}}"/>
        </exec>
    </target>

    <target name="report-run" depends="test,detect-svn" if="svn.wc.present">
        <exec executable="wsl" failonerror="false">
            <arg value="bash"/>
            <arg value="-lc"/>
            <arg value="cd '${wsl.project.dir}' &amp;&amp; svn add '${xml.report.dir}' --force &amp;&amp; svn commit -m '${svn.report.message}' '${xml.report.dir}'"/>
        </exec>
    </target>

    <target name="report-skip" depends="test,detect-svn" unless="svn.wc.present">
        <echo message="SVN working copy not found (.svn is missing). Skipping report target."/>
    </target>

    <target name="report" depends="report-run,report-skip" description="Save JUnit XML and commit to SVN"/>
</project>
